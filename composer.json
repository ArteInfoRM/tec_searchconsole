{
  "name": "tecnoacquisti/tec_searchconsole",
  "description": "PrestaShop module: Google Search Console integration",
  "type": "prestashop-module",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "google/apiclient": "^2.15",
    "monolog/monolog": "^2.9"
  },
  "config": {
    "vendor-dir": "lib/google_vendor",
    "optimize-autoloader": true,
    "prepend-autoloader": false
  },
  "autoload": {
    "psr-4": {
      "Tecnoacquisti\\SearchConsole\\": "classes/"
    }
  }
}
