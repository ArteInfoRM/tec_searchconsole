# Apache 2.2
<IfModule !mod_authz_core.c>
   <FilesMatch "^(?!callback\.php$|cron\.php$).*\.php$">
   order allow,deny
   deny from all
   </FilesMatch>
</IfModule>

# Apache 2.4
<IfModule mod_authz_core.c>
   <FilesMatch "^(?!callback\.php$|cron\.php$).*\.php$">
   Require all denied
   </FilesMatch>
</IfModule>
